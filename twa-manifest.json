{
  "packageId": "com.ktcterminal.portal",
  "host": "portal.ktcterminal.com",
  "name": "KTC Online Portal",
  "launcherName": "KTC Portal",
  "display": "standalone",
  "orientation": "portrait",
  "themeColor": "#f26a21",
  "themeColorDark": "#0e1116",
  "navigationColor": "#0e1116",
  "navigationColorDark": "#0e1116",
  "backgroundColor": "#ffffff",
  "enableNotifications": true,
  "startUrl": "/app",
  "iconUrl": "https://portal.ktcterminal.com/app-icon-512.png",
  "maskableIconUrl": "https://portal.ktcterminal.com/app-icon-maskable.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": { "path": "./android-keystore.jks", "alias": "ktc" },
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "webManifestUrl": "https://portal.ktcterminal.com/manifest.webmanifest",
  "fallbackType": "customtabs",
  "enableSiteSettingsShortcut": true,
  "fullScopeUrl": "https://portal.ktcterminal.com/",
  "minSdkVersion": 21
}
