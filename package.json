{
  "name": "ktcportal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "npm run dev:sandbox",
    "dev:live": "vite",
    "dev:sandbox": "node scripts/dev-web-sandbox.mjs",
    "build": "node scripts/build-web-live.mjs",
    "build:test": "npm run build:sandbox",
    "build:live": "npm run build",
    "build:sandbox": "node scripts/build-web-sandbox.mjs",
    "build:android:test": "npm run build:android:sandbox",
    "build:android:live": "node scripts/build-android-live.mjs",
    "build:android:sandbox": "node scripts/build-android-sandbox.mjs",
    "preview": "vite preview",
    "preview:test": "npm run preview:sandbox",
    "preview:live": "vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "preview:sandbox": "npm run build:sandbox && vite preview --host 127.0.0.1 --port 3000 --strictPort",
    "target:status": "node scripts/target-status.mjs",
    "seed:e2e:owner": "node scripts/seed-e2e-owner.mjs",
    "seed:e2e:consignees": "node scripts/seed-e2e-consignees-from-prod.mjs",
    "lint": "tsc --noEmit",
    "check:i18n": "node scripts/check-i18n.mjs && node scripts/check-i18n-coverage.mjs --strict",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-updater": "^8.50.1",
    "@supabase/supabase-js": "^2.45.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
